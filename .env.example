# --- SQL Server Connection ---
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=<YOUR_SQLSERVER_USERNAME>
SQLSERVER_PASSWORD=<YOUR_SQLSERVER_PASSWORD>
SQLSERVER_DATABASE=master
SQLSERVER_DRIVER={ODBC Driver 18 for SQL Server}
SQLSERVER_TRUST_SERVER_CERTIFICATE=yes

# --- App identity ---
APP_USER_NAME=<YOUR_APP_USER_NAME>
APP_USER_ID=user_001
APP_NAME=zeusai

# --- Model provider ---
MODEL_PROVIDER=google

# Google
GOOGLE_API_KEY=<YOUR_GOOGLE_API_KEY>
PRIMARY_MODEL=gemini-2.5-flash
THINKING_MODEL=gemini-2.5-pro

# OpenAI
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
# MODEL_PRIMARY=openai/gpt-4o-mini
# MODEL_THINKING=openai/gpt-4o

# Anthropic
# MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>
# MODEL_PRIMARY=anthropic/claude-3-5-haiku-20241022
# MODEL_THINKING=anthropic/claude-3-5-sonnet-20241022

# --- Observability / Grafana Cloud (optional) ---
# OTEL_ENABLED=true
# OTEL_SERVICE_NAME=zeusai
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-3.grafana.net/otlp
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<your-base64-token>

# --- Debug & Feature Flags ---
# ZEUSAI_DEBUG=true
# USE_SKILLS=true
